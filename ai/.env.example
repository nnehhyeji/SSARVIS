DATABASE_URL=sqlite+aiosqlite:////data/app.db

OPENAI_API_KEY=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=30.0
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
PROMPT_META_FILE=app/prompts/system_prompt_meta.md

RECENT_CONVERSATIONS_LIMIT=30
SIMILAR_CONVERSATIONS_LIMIT=3
SIMILAR_CONVERSATIONS_PREFIX_FILE=app/prompts/similar_conversations_prefix.md
RESPONSE_GUIDELINE_PROMPT_FILE=app/prompts/response_guideline.md

DASHSCOPE_API_KEY=
DASHSCOPE_TTS_MODEL=qwen3-tts-vc-realtime-2026-01-15
DASHSCOPE_TTS_VOICE_ENROLLMENT_MODEL=qwen-voice-enrollment
DASHSCOPE_TTS_AUDIO_MIME_TYPE=audio/mpeg
DASHSCOPE_TTS_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_TTS_ENROLLMENT_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/audio/tts/customization
DASHSCOPE_TTS_HTTP_TIMEOUT_SECONDS=20.0

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=conversations
QDRANT_TIMEOUT_SECONDS=20.0
QDRANT_VECTOR_SIZE=1536

S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_KEY_PREFIX=

S3_REGION=auto
S3_USE_SSL=true
S3_ADDRESSING_STYLE=path
S3_CREATE_BUCKET_IF_MISSING=false
TTS_PRESIGNED_URL_EXPIRES_SECONDS=3600

OPUS_DLL_DIRECTORY=
OPUS_SAMPLE_RATE=24000
OPUS_CHANNELS=1
OPUS_FRAME_DURATION_MS=40
OPUS_BITRATE=24000
