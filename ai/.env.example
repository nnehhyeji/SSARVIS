OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
LLM_TIMEOUT_SECONDS=30.0
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
PROMPT_META_FILE=app/prompts/system_prompt_meta.md
PROMPT_UPDATE_META_FILE=app/prompts/system_prompt_meta_update.md

SIMILAR_CONVERSATIONS_LIMIT=1
SIMILAR_CONVERSATIONS_PREFIX_FILE=app/prompts/similar_conversations_prefix.md
RESPONSE_GUIDELINE_PROMPT_FILE=app/prompts/response_guideline.md

DASHSCOPE_API_KEY=
TTS_MODEL=qwen3-tts-vc-realtime-2026-01-15
TTS_VOICE_ENROLLMENT_MODEL=qwen-voice-enrollment
TTS_AUDIO_MIME_TYPE=audio/mpeg
TTS_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
TTS_ENROLLMENT_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/audio/tts/customization
TTS_HTTP_TIMEOUT_SECONDS=20.0

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=conversations
QDRANT_TIMEOUT_SECONDS=20.0
QDRANT_VECTOR_SIZE=1536

OPUS_DLL_DIRECTORY=
OPUS_SAMPLE_RATE=24000
OPUS_CHANNELS=1
OPUS_FRAME_DURATION_MS=40
OPUS_BITRATE=24000
